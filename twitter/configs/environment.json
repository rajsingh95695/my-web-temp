{
  "environments": {
    "development": {
      "description": "Local development environment",
      "api_base_url": "http://localhost:8000",
      "database": {
        "host": "localhost",
        "port": 5432,
        "name": "sentiment_dev",
        "username": "dev_user",
        "password": "dev_password"
      },
      "redis": {
        "host": "localhost",
        "port": 6379
      },
      "features": {
        "enable_debug": true,
        "enable_test_data": true,
        "log_level": "DEBUG"
      },
      "limits": {
        "api_rate_limit": 1000,
        "max_tweets_per_request": 50,
        "cache_ttl": 300
      }
    },
    "staging": {
      "description": "Staging environment for testing",
      "api_base_url": "https://staging-api.sentiment.example.com",
      "database": {
        "host": "staging-db.cluster.example.com",
        "port": 5432,
        "name": "sentiment_staging",
        "username": "staging_user",
        "password": "${STAGING_DB_PASSWORD}"
      },
      "redis": {
        "host": "staging-redis.example.com",
        "port": 6379,
        "password": "${STAGING_REDIS_PASSWORD}"
      },
      "features": {
        "enable_debug": false,
        "enable_test_data": false,
        "log_level": "INFO"
      },
      "limits": {
        "api_rate_limit": 5000,
        "max_tweets_per_request": 100,
        "cache_ttl": 1800
      }
    },
    "production": {
      "description": "Production environment",
      "api_base_url": "https://api.sentiment.example.com",
      "database": {
        "host": "production-db.cluster.example.com",
        "port": 5432,
        "name": "sentiment_production",
        "username": "production_user",
        "password": "${PRODUCTION_DB_PASSWORD}"
      },
      "redis": {
        "host": "production-redis.example.com",
        "port": 6379,
        "password": "${PRODUCTION_REDIS_PASSWORD}"
      },
      "features": {
        "enable_debug": false,
        "enable_test_data": false,
        "log_level": "WARNING"
      },
      "limits": {
        "api_rate_limit": 10000,
        "max_tweets_per_request": 200,
        "cache_ttl": 3600
      }
    }
  },
  "common_settings": {
    "app_name": "Twitter Sentiment Analysis Platform",
    "version": "2.1.0",
    "supported_languages": ["en", "es", "fr", "de", "it"],
    "default_timezone": "UTC",
    "date_format": "YYYY-MM-DD",
    "datetime_format": "YYYY-MM-DD HH:mm:ss",
    "max_file_size_mb": 100,
    "allowed_file_types": [".csv", ".json", ".txt"],
    "retry_policy": {
      "max_retries": 3,
      "backoff_factor": 2,
      "status_forcelist": [500, 502, 503, 504]
    },
    "security": {
      "cors_allowed_origins": [
        "http://localhost:3000",
        "https://dashboard.sentiment.example.com",
        "https://admin.sentiment.example.com"
      ],
      "api_key_header": "X-API-Key",
      "jwt_expiry_hours": 24,
      "password_min_length": 12,
      "require_2fa": true
    },
    "monitoring": {
      "health_check_interval": 30,
      "metrics_collection_interval": 60,
      "alert_channels": ["email", "slack", "pagerduty"],
      "performance_thresholds": {
        "api_response_time_ms": 500,
        "database_query_time_ms": 100,
        "cpu_usage_percent": 80,
        "memory_usage_percent": 85
      }
    },
    "backup": {
      "enabled": true,
      "schedule": "0 2 * * *",
      "retention_days": 30,
      "storage_location": "s3://sentiment-backups",
      "encryption_enabled": true
    },
    "scaling": {
      "auto_scaling_enabled": true,
      "min_instances": 2,
      "max_instances": 10,
      "scale_up_cpu_threshold": 70,
      "scale_down_cpu_threshold": 30,
      "scale_up_memory_threshold": 75,
      "scale_down_memory_threshold": 25
    }
  },
  "feature_flags": {
    "enable_bert_model": true,
    "enable_real_time_streaming": true,
    "enable_multilingual_support": false,
    "enable_entity_recognition": false,
    "enable_topic_modeling": false,
    "enable_advanced_analytics": true,
    "enable_export_functionality": true,
    "enable_batch_processing": true,
    "enable_api_documentation": true
  },
  "external_services": {
    "twitter_api": {
      "enabled": true,
      "version": "v2",
      "rate_limit_tweets_per_month": 1000000
    },
    "rapidapi": {
      "enabled": true,
      "plan": "professional",
      "monthly_requests": 10000
    },
    "sentry": {
      "enabled": true,
      "dsn": "${SENTRY_DSN}",
      "environment": "${APP_ENVIRONMENT}"
    },
    "new_relic": {
      "enabled": true,
      "license_key": "${NEW_RELIC_LICENSE_KEY}",
      "app_name": "sentiment-analysis-${APP_ENVIRONMENT}"
    },
    "aws": {
      "s3_bucket": "sentiment-data-${APP_ENVIRONMENT}",
      "cloudwatch_log_group": "sentiment-${APP_ENVIRONMENT}",
      "region": "us-east-1"
    }
  }
}