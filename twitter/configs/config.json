{
  "api": {
    "twitter_api_url": "https://twitter-api45.p.rapidapi.com",
    "timeout": 30,
    "max_retries": 3,
    "retry_delay": 2,
    "rate_limit_per_hour": 1000
  },
  "models": {
    "vader_enabled": true,
    "random_forest_enabled": true,
    "bert_enabled": true,
    "ensemble_weights": {
      "vader": 0.2,
      "random_forest": 0.3,
      "bert": 0.5
    },
    "cache_predictions": true,
    "cache_ttl_seconds": 3600
  },
  "database": {
    "postgres_host": "localhost",
    "postgres_port": 5432,
    "postgres_db": "sentiment_analysis",
    "redis_host": "localhost",
    "redis_port": 6379,
    "redis_db": 0
  },
  "processing": {
    "batch_size": 100,
    "max_tweet_length": 280,
    "language_detection": true,
    "default_language": "en",
    "clean_html": true,
    "remove_urls": true,
    "remove_mentions": true
  },
  "logging": {
    "level": "INFO",
    "file_path": "./logs/app.log",
    "max_file_size_mb": 100,
    "backup_count": 5,
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "monitoring": {
    "enable_metrics": true,
    "prometheus_port": 9090,
    "health_check_interval": 30,
    "alert_email": "alerts@example.com",
    "sentry_dsn": ""
  },
  "security": {
    "api_key_header": "X-API-Key",
    "cors_origins": ["http://localhost:3000", "https://dashboard.example.com"],
    "rate_limiting_enabled": true,
    "max_requests_per_minute": 60,
    "jwt_secret": "change_this_in_production",
    "jwt_expiry_hours": 24
  },
  "features": {
    "real_time_analysis": true,
    "historical_analysis": true,
    "sentiment_trends": true,
    "entity_recognition": false,
    "topic_modeling": false,
    "multilingual_support": false
  },
  "version": "2.1.0",
  "environment": "development"
}